NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# StudySphere AI (server-side only — never use NEXT_PUBLIC_ for these)
# Primary: NVIDIA DeepSeek V4 Flash (fast, efficient)
NVIDIA_API_KEY=
# Optional model override (default: deepseek-ai/deepseek-v4-flash)
# NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash

# Fallback: OpenAI
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.5

# Provider order: auto (default) | nvidia | openai
# auto = NVIDIA first if key exists, then OpenAI
AI_PROVIDER=auto
