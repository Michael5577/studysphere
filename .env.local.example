NEXT_PUBLIC_SUPABASE_URL=
# Use legacy anon key (eyJ...) from Settings → API Keys → Legacy tab
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# StudySphere AI (server-side only — never use NEXT_PUBLIC_ for these)
# Primary: NVIDIA DeepSeek V4 Flash via integrate.api.nvidia.com
NVIDIA_API_KEY=
# NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash

# Fallback: OpenAI Responses API
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.5

# auto = NVIDIA first, then OpenAI | nvidia | openai
AI_PROVIDER=auto
